# Copiá este archivo a .env y reemplazá con tus valores.
# Supabase: Project Settings → Database → Connection string (URI).
# Para migraciones usá la conexión directa (5432). Para la app podés usar pooler (6543)?pgbouncer=true

DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@db.xxx.supabase.co:5432/postgres"

# JWT – acceso y refresh (generá secretos aleatorios en producción)
JWT_SECRET="cambiar-por-secreto-seguro"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="cambiar-por-otro-secreto-refresh"
JWT_REFRESH_EXPIRES_IN="7d"
